{
  "manifest_version": 3,
  "name": "Receipts",
  "version": "0.1.0",
  "description": "Auto-extract order info from Amazon, DoorDash, Uber, Flipkart and save to a local ledger.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://www.amazon.in/*",
    "https://www.doordash.com/*",
    "https://www.ubereats.com/*",
    "https://www.flipkart.com/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Receipts",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.in/*"
      ],
      "js": ["src/content/common.js", "src/content/amazon.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.doordash.com/*"],
      "js": ["src/content/common.js", "src/content/doordash.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.ubereats.com/*"],
      "js": ["src/content/common.js", "src/content/ubereats.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.flipkart.com/*"],
      "js": ["src/content/common.js", "src/content/flipkart.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
